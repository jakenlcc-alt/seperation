# Copy to .env for local dev (netlify dev) or set in Netlify → Environment variables.

# ---- Cloudflare Worker holding the Monday.com token ----
# Base worker URL; the app posts to <url>/graphql automatically.
# e.g. https://monday-token-keeper.jake-nlcc.workers.dev
MONDAY_WORKER_URL=https://your-worker.workers.dev
# Optional shared secret IF you add auth to the Worker (currently open).
MONDAY_WORKER_KEY=
# Optional: workspace new boards are created in
MONDAY_WORKSPACE_ID=

# ---- Google Drive (service account) ----
# Paste the FULL service-account key JSON on one line.
GOOGLE_SERVICE_ACCOUNT_JSON=
# The "04_Projects" folder inside JAKES BRAIN (already filled with the known ID).
DRIVE_PROJECTS_FOLDER_ID=16w_Y_-ZzsZsiDSnJaSkKjGKtKau09dy6
